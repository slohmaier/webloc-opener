<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>webloc-opener</AssemblyName>
    <RootNamespace>WeblocOpener</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>Stefan Lohmaier</Authors>
    <Product>webloc-opener</Product>
    <Description>Opens macOS .webloc shortcut files on Windows</Description>
    <InvariantGlobalization>true</InvariantGlobalization>
    <ApplicationIcon>icon\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="icon\app.ico" />
    <None Include="icon\app.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="plist-cil" Version="2.3.1" />
  </ItemGroup>

</Project>
